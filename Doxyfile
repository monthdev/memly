PROJECT_NAME = "Memly Project"
PROJECT_BRIEF = "Memly Project documentation"

OUTPUT_DIRECTORY = doc/doxygen
HTML_OUTPUT = html
GENERATE_HTML = YES
GENERATE_LATEX = NO
GENERATE_XML = NO
GENERATE_TREEVIEW = YES

INPUT = README.md doc/AGENTS_CODING_GUIDE.md src
USE_MDFILE_AS_MAINPAGE = README.md
RECURSIVE = YES
FILE_PATTERNS = *.cpp *.hpp *.h *.cc *.cxx *.dox *.md

EXTRACT_ALL = NO
EXTRACT_PRIVATE = YES
EXTRACT_STATIC = NO
HIDE_UNDOC_MEMBERS = NO
HIDE_UNDOC_CLASSES = NO
WARN_IF_UNDOCUMENTED = NO
WARN_IF_DOC_ERROR = YES
WARN_AS_ERROR = FAIL_ON_WARNINGS

MARKDOWN_SUPPORT = YES
AUTOLINK_SUPPORT = YES
JAVADOC_AUTOBRIEF = NO
QT_AUTOBRIEF = NO
MULTILINE_CPP_IS_BRIEF = NO

FULL_PATH_NAMES = YES
STRIP_FROM_PATH = .

SOURCE_BROWSER = YES
INLINE_SOURCES = YES
STRIP_CODE_COMMENTS = NO
REFERENCES_LINK_SOURCE = YES
VERBATIM_HEADERS = YES
QUIET = YES
